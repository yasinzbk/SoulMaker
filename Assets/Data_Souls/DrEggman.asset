  m_Script: {fileID: 11500000, guid: a68dcd5d31e684d4f8fa33d4ccd3de02, type: 3}
  m_Name: DrEggman
  m_EditorClassIdentifier: Assembly-CSharp::SoulData
  soulName: Ivo Eggman
  baseSprite: {fileID: 1792722197823829547, guid: c577c41b4c0c06b4bb809c9bf41ad172, type: 3}
  fullBackstory: "Lakap: Dr. Eggman\n\r\nGe\xE7mi\u015F: \xD6nceki hayat\u0131nda
    bir\xE7ok can kurtarm\u0131\u015F ba\u015Far\u0131l\u0131 bir doktordu.\n\r\n\xD6l\xFCm
    \u015Fekli: \u0130ntihar.\n\r\nSon s\xF6z\xFC: \"\xD6z\xFCr dilerim...\""
  soulCoins: 6
  dialogueLines:
  - text: Merhaba...
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "Ben Dr. Eggman, en az\u0131ndan \xF6nceki hayat\u0131mda \xF6yle biliniyordum."
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: Ah... buraya reenkarne olmaya geldim...
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "yani anlayaca\u011F\u0131n, senden bir ricam var."
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "Asl\u0131nda \xF6nceki hayat\u0131mda can\u0131mdan \xE7ok sevdi\u011Fim
      bir ailem vard\u0131..."
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "1 k\u0131z\u0131m, 1 o\u011Flum ve d\xFCnyalar g\xFCzeli bir e\u015Fim."
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "Fakat... onlar benden \xF6nce buraya geldiler ve reenkarne oldular san\u0131r\u0131m."
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "Bir ihtimal onlarla tekrar olabilme \u015Fans\u0131m var m\u0131 acaba?"
    emotion: 0
    expression: {fileID: -7188612737034681094, guid: ac0bacd38517af542a01b4a75ce1c887, type: 3}
  - text: "L\xFCtfen?"
    emotion: 1
    expression: {fileID: -834700764009628627, guid: 771be68cbf762cd4e9772ba0b9332fac, type: 3}
  optionA:
    lifeLabel: 8
    lifeDescription: "Ailesinin yan\u0131nda reenkarne olmas\u0131"
    coinCost: 8
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
  optionB:
    lifeLabel: 4
    lifeDescription: "Sava\u015F\u0131n ortas\u0131nda bir bebek olarak reenkarne
      olmas\u0131"
    coinCost: 4
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
