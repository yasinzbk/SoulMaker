  m_Script: {fileID: 11500000, guid: a68dcd5d31e684d4f8fa33d4ccd3de02, type: 3}
  m_Name: Asker
  m_EditorClassIdentifier: Assembly-CSharp::SoulData
  soulName: Combat Pilot Tarik Watanabe
  baseSprite: {fileID: -7582364231757599730, guid: 7ddedc18c90b61541bdd2ec9b5ba073e, type: 3}
  fullBackstory: "Combat Pilot Tarik Watanabe\n\nLakap: (Flieger-Horst 7/204) / Gekitsui-O
    / East-027\n\r\nGe\xE7mi\u015F: \xD6nceki hayat\u0131nda \xFClkesi i\xE7in kendini
    feda etmi\u015F bir sava\u015F pilotu.\n\r\n\xD6l\xFCm \u015Fekli: Kamikaze.\n\r\nSon
    s\xF6z\xFC: \"Kesinlikle bir d\xFC\u015Fman sava\u015F gemisini dibe g\xF6nderece\u011Fim.
    Tenno Heika BANZA\u0130\u0130\u0130!!!\""
  soulCoins: 5
  dialogueLines:
  - text: "Nagazakili Er Watanabe Tarik, emret komutan\u0131m!"
    emotion: 0
    expression: {fileID: -7582364231757599730, guid: 7ddedc18c90b61541bdd2ec9b5ba073e, type: 3}
    voiceLine: {fileID: 8300000, guid: 68cb86699c3166e4b8c5c454987eb1b0, type: 3}
  - text: "...Ah, eski al\u0131\u015Fkanl\u0131klar, affedersin. "
    emotion: 3
    expression: {fileID: 7742508237215608095, guid: a9c2eead9f3a93743a1bab2ea3a6f80b, type: 3}
    voiceLine: {fileID: 8300000, guid: 1564eaf309684254c9d6855c839fca75, type: 3}
  - text: "Reenkarne olmaya geldim, tabii siz nas\u0131l uygun g\xF6r\xFCrseniz efendim."
    emotion: 0
    expression: {fileID: -7582364231757599730, guid: 7ddedc18c90b61541bdd2ec9b5ba073e, type: 3}
    voiceLine: {fileID: 8300000, guid: 34fe11e06b3529a4ba0072c3008f139f, type: 3}
  optionA:
    lifeLabel: 5
    lifeDescription: "Amerika'da orta h\xE2lli bir ailede yeniden do\u011F"
    coinCost: 5
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -7582364231757599730, guid: 7ddedc18c90b61541bdd2ec9b5ba073e, type: 3}
    endingText: "Tarik Amerika'da Afro-Amerikan olarak do\u011Fdu ve uzun bir s\xFCre
      \u0131rk\xE7\u0131l\u0131\u011Fa u\u011Frad\u0131, ama bir \u015Fekilde atlatmay\u0131
      ba\u015Far\u0131p ba\u015Far\u0131l\u0131 bir vatanda\u015F oldu."
  optionB:
    lifeLabel: 5
    lifeDescription: "Afrika'da bir kabilede yeniden do\u011F"
    coinCost: 5
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: 7742508237215608095, guid: a9c2eead9f3a93743a1bab2ea3a6f80b, type: 3}
    endingText: "Afrika'daki kabilesinde bir \xE7ocuk olarak do\u011Fan Tar\u0131k,
      iyi bak\u0131lmamas\u0131 \xFCzerine daha bebekken engelli kald\u0131 ve kabilenin
      delisi ilan edildi."
