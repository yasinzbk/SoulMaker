  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a68dcd5d31e684d4f8fa33d4ccd3de02, type: 3}
  m_Name: Sokrates
  m_EditorClassIdentifier: Assembly-CSharp::SoulData
  soulName: 'Sokrates '
  baseSprite: {fileID: -2889826238054235022, guid: 12cf5bd49e46fcc4cb9095bae84d6c9d, type: 3}
  fullBackstory: "Lakap: Absolute Rage Baiter / Platon'un Hayali Arkada\u015F\u0131\n\r\nGe\xE7mi\u015F:
    Bat\u0131 felsefesinin kurucular\u0131ndan biri olarak kabul edilmi\u015F ve
    ahlaki d\xFC\u015F\xFCnce gelene\u011Fine \xF6nc\xFCl\xFCk etmi\u015F Atinal\u0131
    bir Yunan filozof. Hi\xE7bir yaz\u0131l\u0131 eser b\u0131rakmayan Sokrates'in
    d\xFC\u015F\xFCnceleri, b\xFCy\xFCk \xF6l\xE7\xFCde \xF6\u011Frencileri Platon
    ve Ksenofon'un aktard\u0131\u011F\u0131 diyaloglar arac\u0131l\u0131\u011F\u0131yla
    d\xFCnyaya yay\u0131lm\u0131\u015Ft\u0131r ve bir\xE7ok insan\u0131 rahats\u0131z...
    \xF6hm... yani bir\xE7ok insan\u0131 d\xFC\u015F\xFCnmeye itmi\u015Ftir.\n\r\n\xD6l\xFCm
    \u015Fekli: Zehirle idam edildi.\n\r\nSon s\xF6z\xFC: \"Kriton, Asklepios'a bir
    horoz borcumuz var; \xF6demeyi sak\u0131n unutma.\""
  soulCoins: 3
  dialogueLines:
  - text: "Hey, buralarda bir yerde bir iskelet g\xF6rd\xFCn m\xFC?"
    emotion: 2
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 494923872770051458962b1380f69b48, type: 3}
  - text: "...Peki, ba\u015Fka bir \u015Fey deneyelim"
    emotion: 0
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 0e11828fb0eb83d4b8b807437df9d173, type: 3}
  - text: If judge is your power, what are you without it?
    emotion: 0
    expression: {fileID: 2496706940429432757, guid: 8bc2c428937c310428f045146647f71a, type: 3}
    voiceLine: {fileID: 8300000, guid: e440af5fd78f3784c838103d458bdf87, type: 3}
  - text: ..Agh, cevap vermeni beklemiyordum zaten...
    emotion: 2
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 2583c319a63db8e40a9059d4a9013024, type: 3}
  - text: "Fazla sessiz de\u011Fil misin?"
    emotion: 0
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 87a59dbc41d175d43bde8903907bb607, type: 3}
  - text: "Neyse, burada mutlak karar mercii sensin, bana s\xF6z d\xFC\u015Fmez... "
    emotion: 0
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 377f23d865c926643a5d0dbe15a3c451, type: 3}
  - text: "mi acaba? ...Neyse ne, hadi karar\u0131n\u0131 ver."
    emotion: 0
    expression: {fileID: 4032518421764823770, guid: 4c6f2912b80cb6241aa51f3c2e8258f8, type: 3}
    voiceLine: {fileID: 8300000, guid: 7fa0315e933ab0e48a075ad14b2a8b72, type: 3}
  optionA:
    lifeLabel: 3
    lifeDescription: "\xC7in'de bir k\u0131z \xE7ocu\u011Fu olarak do\u011F"
    coinCost: 3
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -2889826238054235022, guid: 12cf5bd49e46fcc4cb9095bae84d6c9d, type: 3}
    endingText: "do\u011Fdu\u011Fu anda \xF6ld\xFCr\xFCl\xFCr\u2026"
  optionB:
    lifeLabel: 3
    lifeDescription: "Arabistan'da bir k\u0131z \xE7ocu\u011Fu olarak do\u011F"
    coinCost: 3
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -2889826238054235022, guid: 12cf5bd49e46fcc4cb9095bae84d6c9d, type: 3}
    endingText: "do\u011Fdu\u011Fu anda k\u0131z \xE7ocu\u011Fu oldu\u011Funu g\xF6ren
      ailesi onu canl\u0131 canl\u0131 g\xF6mer\u2026"
