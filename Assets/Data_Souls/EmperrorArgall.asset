  m_Script: {fileID: 11500000, guid: a68dcd5d31e684d4f8fa33d4ccd3de02, type: 3}
  m_Name: EmperrorArgall
  m_EditorClassIdentifier: Assembly-CSharp::SoulData
  soulName: Argall von Minos
  baseSprite: {fileID: -7598041566568884402, guid: e2427d10fce4ec540a180466130b75b3, type: 3}
  fullBackstory: "Lakap: G\xFCneyin B\xFCy\xFCk \u0130mparatoru / Refah Getiren /
    Zulm\xFCn Habercisi\n\r\nGe\xE7mi\u015F: \xD6nceki hayat\u0131nda \xFClkesine
    ve halk\u0131na refah getirmi\u015F, fakat sava\u015Ft\u0131\u011F\u0131 \xFClkelere
    zulmetmi\u015F ve k\xF6lele\u015Ftirmi\u015F bir imparator.\n\r\n\xD6l\xFCm \u015Fekli:
    Suikast.\n\r\nSon s\xF6z\xFC: \"Sen de mi Br\xFCt\xFCs...\""
  soulCoins: 17
  dialogueLines:
  - text: "Merhaba. Ben Y\xFCce \u0130mparator Argall von Minos. "
    emotion: 0
    expression: {fileID: -8628307796927150301, guid: b8c2e6db68f7e3f4abc0dfccf65710ba, type: 3}
  - text: "Buraya reenkarne olmaya geldim. Umar\u0131m do\u011Fru karar\u0131 verirsin."
    emotion: 0
    expression: {fileID: -8628307796927150301, guid: b8c2e6db68f7e3f4abc0dfccf65710ba, type: 3}
  optionA:
    lifeLabel: 17
    lifeDescription: "Soylu bir ailede yeniden do\u011F"
    coinCost: 17
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: 3938364124659942936, guid: 297ca39dfdadee442b555449fa15bfa8, type: 3}
    endingText: "Do\u011Fdu\u011Fu soylu ailede yeniden imparator olma \u015Fans\u0131
      vard\u0131, ancak \xE7ok \xFC\u015Fenge\xE7 bir insand\u0131 ve potansiyelini
      heba etmekten ba\u015Fka bir \u015Fey yapmad\u0131. Sonucunda taht i\xE7in
      kavga eden karde\u015Fleri taraf\u0131ndan suikaste kurban gitti\u2026"
  optionB:
    lifeLabel: 2
    lifeDescription: "\u0130mparatorluk alt\u0131nda y\xF6netilen kukla bir \xFClkede
      k\xF6le olarak do\u011F"
    coinCost: 2
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -7598041566568884402, guid: e2427d10fce4ec540a180466130b75b3, type: 3}
    endingText: "K\xF6le olarak do\u011Fdu\u011Fu andan itibaren her g\xFCn\xFC i\u015Fkence
      gibi olan bu adam\u0131n, bu kaderin alt\u0131nda ezilece\u011Fini sanm\u0131\u015F
      olabilirsiniz. Lakin o, hayat\u0131 boyunca her zorlu\u011Fa g\xF6\u011F\xFCs
      gerip k\xF6lelikten kurtularak imparatorlu\u011Fu devirecek bir devrim ordusu
      kurmay\u0131 ba\u015Farm\u0131\u015F ve imparatorlu\u011Fu devirip \xFClkesinde
      cumhuriyeti ilan etmi\u015Ftir. Bunun \xFCst\xFCne, \xFClkesine refah getirmekle
      kalmam\u0131\u015F; zulm\xFC tatm\u0131\u015F biri olarak sava\u015F kar\u015F\u0131t\u0131
      bir tutum sergilemi\u015F ve b\xFCy\xFCk bar\u0131\u015F ve refah devriminin
      \xF6nc\xFCs\xFC olmu\u015Ftur. Bulundu\u011Fu d\xFCnyay\u0131 tamamen de\u011Fi\u015Fime
      s\xFCr\xFCkleyerek 80'lerinde emekli olmu\u015F ve huzurlu bir g\xF6l evinde
      hayata g\xF6zlerini yummu\u015Ftur."
