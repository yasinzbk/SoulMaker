  soulName: Kuro Dizo
  baseSprite: {fileID: 8500915850491075307, guid: 5e80abf5764b17c48baddd0533caac76, type: 3}
  fullBackstory: "T\xFCrkiye bu b\xF6ce\u011Fene yapm\u0131\u015F"
  soulCoins: 3
  dialogueLines:
  - text: "Bi gidi\u015Fimiz, bir de geli\u015Fimiz olur BABBBAAA!"
    emotion: 4
    expression: {fileID: 8500915850491075307, guid: 5e80abf5764b17c48baddd0533caac76, type: 3}
    voiceLine: {fileID: 8300000, guid: 8d456e034934ad246858a11fb453cafa, type: 3}
  - text: "Bizde az de\u011Filiz ha, haberin olsun day\u0131\u0131! "
    emotion: 3
    expression: {fileID: -9186526237936838828, guid: dad8af4b9742e0142add2ed75953548a, type: 3}
    voiceLine: {fileID: 8300000, guid: b55e8008e956af74eb9e16ed86cc9273, type: 3}
  - text: "Yarg\u0131\xE7 bana iyi bir kader ayarla yoksa seni pis ederim ha\u011F!"
    emotion: 3
    expression: {fileID: -9186526237936838828, guid: dad8af4b9742e0142add2ed75953548a, type: 3}
    voiceLine: {fileID: 8300000, guid: d25af38e7efd872448f9fcde95b74b88, type: 3}
  optionA:
    lifeLabel: 1
    lifeDescription: "Guvenli\u011Fe haber ver"
    coinCost: 0
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: 8500915850491075307, guid: 5e80abf5764b17c48baddd0533caac76, type: 3}
    endingText: Guvenlik Goturdu
  optionB:
    lifeLabel: 0
    lifeDescription: "Sakura Jam'de Mikrop olarak yeniden do\u011F"
    coinCost: 0
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -8535991811173944212, guid: c1a8a7245d8873745ac63172524a6ef3, type: 3}
    endingText: "\u015Euanda bizi izliyor"
