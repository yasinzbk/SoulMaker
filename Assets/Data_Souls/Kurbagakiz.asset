  m_Script: {fileID: 11500000, guid: a68dcd5d31e684d4f8fa33d4ccd3de02, type: 3}
  m_Name: Kurbagakiz
  m_EditorClassIdentifier: Assembly-CSharp::SoulData
  soulName: Yue Xue
  baseSprite: {fileID: -4825247317447833179, guid: bf2f3b44877b98849a8e1c463dee7f61, type: 3}
  fullBackstory: "Ge\xE7mi\u015F: \xD6nceki hayat\u0131nda \xC7in'de ya\u015Fayan
    s\u0131radan bir kurba\u011Fa.\n\r\n\xD6l\xFCm \u015Fekli: \u0130\xE7inde torpil
    patlam\u0131\u015F...\n\r\nSon s\xF6z\xFC: \"WRAAKKKKKKKK!!!\""
  soulCoins: 0
  dialogueLines:
  - text: "Mewhaba, wrak \u2014 a, pardon. "
    emotion: 0
    expression: {fileID: -4825247317447833179, guid: bf2f3b44877b98849a8e1c463dee7f61, type: 3}
  - text: "\u015Eey, reenkarne olmaya geldim de... iiii, m\xFCmk\xFCnse \xC7in olmas\u0131n..."
    emotion: 0
    expression: {fileID: 9103029724409692841, guid: 8e0927f7fd569e74f813d62da09f06c5, type: 3}
  - text: "\xC7inli \xE7ocuklardan nefret ediyorum..."
    emotion: 1
    expression: {fileID: -7442742369925825077, guid: bdef9e4cb7049da4ebabbcb39f987426, type: 3}
  optionA:
    lifeLabel: 0
    lifeDescription: "\xC7in'de fakir bir ailede insan olarak yeniden do\u011F "
    coinCost: 0
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -4825247317447833179, guid: bf2f3b44877b98849a8e1c463dee7f61, type: 3}
    endingText: "\xC7in'de fakir bir ailede erkek \xE7ocu\u011Fu olarak yeniden do\u011Far
      ve k\xFC\xE7\xFCk ya\u015Fta \xE7ocuk i\u015F\xE7i yap\u0131l\u0131r, Temu'da
      \xE7al\u0131\u015Ft\u0131r\u0131l\u0131r. B\xFCy\xFCd\xFC\u011F\xFCnde de \xE7ok
      farkl\u0131 bir i\u015F yapmaz; bir fabrika i\u015F\xE7isi olarak 40'lar\u0131nda
      kanserden hayata g\xF6zlerini yumar."
  optionB:
    lifeLabel: 3
    lifeDescription: "Hua Da\u011F\u0131 Mezhebinde taht i\xE7in en olas\u0131 varis
      olarak do\u011F"
    coinCost: 3
    bonusSoul: {fileID: 0}
    appearanceDayOffset: 0
    endingSprite: {fileID: -7442742369925825077, guid: bdef9e4cb7049da4ebabbcb39f987426, type: 3}
    endingText: "Mezhep i\xE7inde en olas\u0131 varis olmas\u0131 k\u0131skan\u0131l\u0131r
      ve imparatori\xE7e ilan edilece\u011Fi t\xF6renden \xF6nce y\xFCz\xFCne s\xFCr\xFClen
      makyaj pudras\u0131na zehir kat\u0131l\u0131r. Tam t\xF6renin ortas\u0131nda,
      g\xF6zlerinden kanlar akarak ve \xE7\u0131\u011Fl\u0131klar i\xE7inde ac\u0131
      \xE7ekerek \xF6l\xFCr\u2026"
